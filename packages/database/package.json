{
	"name": "@cronicorn/database",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:deploy": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"db:reset": "ts-node src/reset.ts",
		"db:seed": "ts-node src/seed.ts",
		"db:up": "docker-compose up -d",
		"clean": "rm -rf node_modules && rm -rf .turbo && rm -rf generated"
	},
	"exports": {
		".": "./src/index.ts",
		"./jobs": "./src/jobs/index.ts",
		"./users": "./src/users/index.ts",
		"./common": "./src/common/index.ts",
		"./messages": "./src/messages/index.ts",
		"./dev-user": "./src/dev-user.ts"
	},
	"devDependencies": {
		"dotenv-cli": "^8.0.0",
		"drizzle-kit": "^0.31.4",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.3"
	},

	"dependencies": {
		"@cronicorn/typescript-config": "workspace:*",
		"@neondatabase/serverless": "^1.0.1",
		"@types/node": "^22.15.3",
		"dotenv": "^17.1.0",
		"drizzle-orm": "^0.44.2",
		"drizzle-seed": "^0.3.1",
		"postgres": "^3.4.7"
	}
}
